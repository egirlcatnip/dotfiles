{
  "breadcrumbs.enabled": false,
  // Catppuccin Theme Settings
  "catppuccin-icons.hidesExplorerArrows": true,
  "catppuccin.accentColor": "lavender",
  // Code Runner Settings
  "code-runner.executorMap": {
    "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "ahk": "autohotkey",
    "applescript": "osascript",
    "autoit": "autoit3",
    "bat": "cmd /c",
    "c": "cd $dir && clang $fileName -o $fileNameWithoutExt.exe && ./$fileNameWithoutExt.exe",
    "clojure": "lein exec",
    "coffeescript": "coffee",
    "cpp": "cd $dir && clang  $fileName -o $fileNameWithoutExt.exe && ./$fileNameWithoutExt.exe",
    "crystal": "crystal",
    "csharp": "scriptcs",
    "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
    "dart": "dart",
    "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "fsharp": "fsi",
    "go": "go run",
    "groovy": "groovy",
    "haskell": "runhaskell",
    "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
    "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
    "javascript": "node",
    "julia": "julia",
    "kit": "kitc --run",
    "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
    "lisp": "sbcl --script",
    "lua": "lua",
    "nim": "nim compile --verbosity:0 --hints:off --run",
    "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "ocaml": "ocaml",
    "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutTrailingSlash",
    "perl": "perl",
    "perl6": "perl6",
    "php": "php",
    "powershell": "powershell -ExecutionPolicy ByPass -File",
    "python": "python -u",
    "r": "Rscript",
    "racket": "racket",
    "ruby": "ruby",
    "rust": "cd $dir && cargo run -q",
    "sass": "sass --style expanded",
    "scala": "scala",
    "scheme": "csi -script",
    "scss": "scss --style expanded",
    "shellscript": "bash",
    "swift": "swift",
    "typescript": "ts-node",
    "v": "v run",
    "vbscript": "cscript //Nologo",
  },
  "code-runner.ignoreSelection": true,
  "code-runner.preserveFocus": false,
  "code-runner.saveFileBeforeRun": true,
  "code-runner.showExecutionMessage": false,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": false,
  "editor.codeLens": false,
  "editor.cursorBlinking": "phase",
  // Editor Settings
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 10,
  "editor.cursorWidth": 2,
  "editor.dragAndDrop": false,
  "editor.foldingHighlight": false,
  "editor.fontFamily": "Monolisa, JetBrainsMono Nerd Font",
  "editor.fontLigatures": "'calt', 'liga', 'zero', 'ss04', 'ss06', 'ss10', 'ss13'",
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.inlayHints.enabled": "off",
  "editor.inlineSuggest.syntaxHighlightingEnabled": true,
  "editor.minimap.autohide": true,
  "editor.minimap.renderCharacters": false,
  "editor.multiCursorModifier": "ctrlCmd",
  "editor.occurrencesHighlight": "off",
  "editor.padding.bottom": 16,
  "editor.padding.top": 16,
  "editor.quickSuggestionsDelay": 0,
  "editor.renderLineHighlight": "none",
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.horizontalScrollbarSize": 0,
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.verticalScrollbarSize": 0,
  "editor.smoothScrolling": true,
  "editor.suggest.matchOnWordStartOnly": false,
  "editor.suggest.preview": true,
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.wordWrap": "on",
  "editor.wrappingStrategy": "advanced",
  "errorLens.messageBackgroundMode": "message",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": false,
  "explorer.sortOrder": "type",
  "file-browser.hideIgnoredFiles": true,
  "file-browser.labelIgnoredFiles": true,
  "files.associations": {
    "CompilerExplorer": "asm-intel-x86-generic",
    ".clang-format": "json",
    "*.h": "c"
  },
  "files.readonlyFromPermissions": true,
  "files.simpleDialog.enable": true,
  "files.trimTrailingWhitespace": true,
  // Git Settings
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "github.copilot.advanced": {
    "authProvider": "github"
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false
  },
  // Security Settings
  "security.workspace.trust.enabled": false,
  // Telemetry Settings
  "telemetry.telemetryLevel": "off",
  // Terminal Settings
  "terminal.external.linuxExec": "ptyxis",
  "terminal.integrated.commandsToSkipShell": [
    "code-runner.run"
  ],
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "none",
  "terminal.integrated.cursorWidth": 2,
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.persistentSessionReviveProcess": "never",
  "terminal.integrated.profiles.linux": {
    "bash": {
      "icon": "terminal-bash",
      "path": "bash"
    },
    "fish": {
      "path": "fish"
    },
    "pwsh": {
      "icon": "terminal-powershell",
      "path": "pwsh"
    }
  },
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.shellIntegration.history": 1000,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.wordSeparators": " ()[]{}',`─‘’“”|_",
  // Update Settings
  "update.mode": "none",
  "update.showReleaseNotes": false,
  // Window Settings
  "window.autoDetectColorScheme": true,
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "toggle",
  "window.newWindowDimensions": "maximized",
  "window.restoreFullscreen": true,
  "window.title": "${rootName}",
  "window.titleBarStyle": "custom",
  "window.zoomLevel": 1,
  // Workbench Settings
  "workbench.editor.empty.hint": "hidden",
  "workbench.enableExperiments": false,
  "workbench.iconTheme": null,
  "workbench.list.smoothScrolling": true,
  "workbench.colorTheme": "Adwaita Dark & Github syntax highlighting",
  "workbench.preferredLightColorTheme": "Adwaita Light & Github syntax highlighting",
  "workbench.preferredDarkColorTheme": "Adwaita Dark & Github syntax highlighting",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  // Zen Mode Settings
  "zenMode.centerLayout": false,
  "zenMode.fullScreen": false,
  "zenMode.showTabs": "none",
  "workbench.commandPalette.experimental.askChatLocation": "quickChat",
  "workbench.commandPalette.experimental.suggestCommands": true,
  "debug.toolBarLocation": "hidden",
  "debug.console.acceptSuggestionOnEnter": "on",
  "accessibility.verbosity.debug": false,
  "debug.internalConsoleOptions": "neverOpen",
  "debug.terminal.clearBeforeReusing": true,
  "debug.showVariableTypes": true,
  "lldb.showDisassembly": "never",
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.pdb": "default"
  },
  "code-runner.showRunCommandInEditorContextMenu": false,
  "code-runner.runInTerminal": true,
  "code-runner.clearPreviousOutput": false,
  "hexeditor.columnWidth": 16,
  "hexeditor.showDecodedText": true,
  "hexeditor.defaultEndianness": "little",
  "hexeditor.inspectorType": "aside",
  "task.autoDetect": "off",
  "workbench.editor.editorActionsLocation": "titleBar",
  "window.commandCenter": false,
  "debugControlsInTitlebar.hideDebugStart": true,
  "workbench.layoutControl.enabled": false,
  "code-runner.showStopIconInEditorTitleMenu": false,
  "workbench.panel.showLabels": false,
  "breadcrumbs.icons": false,
  "errorLens.statusBarIconsEnabled": true,
  "workbench.editor.highlightModifiedTabs": true,
  "editor.semanticTokenColorCustomizations": {
    "enabled": true,
  },
  "window.customTitleBarVisibility": "auto",
  "git.autofetch": true,
  "explorer.confirmDragAndDrop": false,
  "custom-ui-style.font.monospace": "JetBrainsMono Nerd Font",
  "custom-ui-style.font.sansSerif": "JetBrainsMono Nerd Font",
  "terminal.integrated.defaultProfile.windows": "Nushell",
  "chat.editing.alwaysSaveWithGeneratedChanges": true,
  "errorLens.messageEnabled": true,
  "zig.zls.enabled": "on",
  "c3.lsp.path": "c:\\Users\\egirlcatnip\\AppData\\Roaming\\VSCodium\\User\\globalStorage\\c3.vscode-c3\\c3lsp_install\\server\\bin\\release\\c3lsp.exe",
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "terminal.integrated.enablePersistentSessions": false,
  "editor.stickyScroll.enabled": false
}