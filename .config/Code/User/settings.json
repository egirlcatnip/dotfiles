{
    "C_Cpp.clang_format_fallbackStyle": "LLVM",
    "C_Cpp.intelliSenseEngine": "disabled",
    "breadcrumbs.icons": false,
    "catppuccin-icons.hidesExplorerArrows": true,
    "catppuccin.accentColor": "lavender",
    "code-runner.customCommand": "echo Hello",
    "code-runner.clearPreviousOutput": false,
    "code-runner.enableAppInsights": false,
    "code-runner.executorMap": {
        "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "ahk": "autohotkey",
        "applescript": "osascript",
        "autoit": "autoit3",
        "bat": "cmd /c",
        "c": "cd $dir && clang $fileName -o $fileNameWithoutExt.exe && ./$fileNameWithoutExt.exe",
        "clojure": "lein exec",
        "coffeescript": "coffee",
        "cpp": "cd $dir && clang++ $fileName -o $fileNameWithoutExt.exe && $dir$fileNameWithoutExt.exe",
        "crystal": "crystal",
        "csharp": "scriptcs",
        "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        "dart": "dart",
        "erlang": "escript",
        "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fsharp": "fsi",
        "gleam": "gleam run -m $fileNameWithoutExt",
        "go": "go run",
        "groovy": "groovy",
        "haskell": "runghc",
        "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
        "javascript": "node",
        "julia": "julia",
        "kit": "kitc --run",
        "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
        "lisp": "sbcl --script",
        "lua": "lua",
        "mojo": "mojo run",
        "nim": "nim compile --verbosity:0 --hints:off --run",
        "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "ocaml": "ocaml",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        "perl": "perl",
        "perl6": "perl6",
        "php": "php",
        "pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "python": "python -u",
        "r": "Rscript",
        "racket": "racket",
        "ruby": "ruby",
        "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
        "sass": "sass --style expanded",
        "scala": "scala",
        "scheme": "csi -script",
        "scss": "scss --style expanded",
        "shellscript": "bash",
        "sml": "cd $dir && sml $fileName",
        "spwn": "spwn build",
        "swift": "swift",
        "typescript": "ts-node",
        "v": "v run",
        "vbscript": "cscript //Nologo",
        "zig": "zig run"
    },
    "code-runner.ignoreSelection": true,
    "code-runner.preserveFocus": false,
    "code-runner.runInTerminal": true,
    "code-runner.showExecutionMessage": false,
    "diffEditor.experimental.showMoves": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorSurroundingLines": 10,
    "editor.cursorWidth": 2,
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontLigatures": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.minimap.renderCharacters": false,
    "editor.quickSuggestionsDelay": 0,
    "editor.suggest.matchOnWordStartOnly": false,
    "editor.suggest.preview": true,
    "editor.suggestSelection": "recentlyUsedByPrefix",
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "file-browser.hideIgnoredFiles": true,
    "file-browser.labelIgnoredFiles": true,
    "files.readonlyFromPermissions": true,
    "files.simpleDialog.enable": true,
    "files.trimTrailingWhitespace": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "intelephense.telemetry.enabled": false,
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nil",
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.diagnostics.styleLints.enable": true,
    "security.workspace.trust.enabled": false,
    "settingsSync.keybindingsPerPlatform": false,
    "telemetry.telemetryLevel": "off",
    "terminal.external.linuxExec": "ptyxis",
    "terminal.integrated.commandsToSkipShell": [
        "code-runner.run"
    ],
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorStyleInactive": "none",
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.enableImages": true,
    "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    "terminal.integrated.shellIntegration.history": 1000,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.wordSeparators": " ()[]{}',\"`─‘’“”|_",
    "update.mode": "none",
    "window.autoDetectColorScheme": true,
    "window.commandCenter": false,
    "window.customTitleBarVisibility": "never",
    "window.dialogStyle": "custom",
    "window.menuBarVisibility": "compact",
    "window.newWindowDimensions": "maximized",
    "window.title": "${dirty}${activeEditorShort}${separator}${rootNameShort}",
    "window.titleBarStyle": "native",
    "window.zoomLevel": 1,
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.editor.empty.hint": "hidden",
    "workbench.enableExperiments": false,
    "workbench.preferredDarkColorTheme": "Adwaita Dark",
    "workbench.preferredLightColorTheme": "Adwaita Light",
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false
}
